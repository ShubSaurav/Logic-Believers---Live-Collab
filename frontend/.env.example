# Optional overrides for API/WS target
# By default, frontend uses the browser hostname with backend port 3001.
# Example: if frontend is opened at http://192.168.1.20:5173, API defaults to http://192.168.1.20:3001
# VITE_API_BASE_URL="http://192.168.1.20:3001"
# VITE_WS_BASE_URL="ws://192.168.1.20:3001"

VITE_API_PROTOCOL="http"
VITE_API_PORT="3001"
